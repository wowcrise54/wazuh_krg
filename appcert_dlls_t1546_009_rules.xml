<!--
  Wazuh 4.14 port of MaxPatrol SIEM rules PT-CR-1349
  (AppCert_DLLs_Persist) and the AppCert entry used by PT-CR-1360
  (Suspicious_Registry_Value). MITRE ATT&CK T1546.009.
-->
<group name="windows,appcert_dlls,t1546_009,">

  <!-- PT-CR-1360 table entry: key/value creation or modification. -->
  <rule id="110320" level="12">
    <if_sid>61614,61615</if_sid>
    <field name="win.eventdata.targetObject" type="pcre2">(?i)\\Control\\Session Manager\\AppCertDlls\\AppCert$</field>
    <description>AppCert DLL persistence registry artifact detected: $(win.eventdata.targetObject), process $(win.eventdata.image), user $(win.eventdata.user).</description>
    <mitre><id>T1546.009</id></mitre>
    <group>sysmon,attack,persistence,privilege_escalation,event_triggered_execution,registry,appcert_dlls,</group>
  </rule>

  <!-- PT-CR-1349: Event 13 exposes the registered payload value. -->
  <rule id="110321" level="12">
    <if_sid>110320</if_sid>
    <field name="win.system.eventID">^13$</field>
    <description>AppCert DLL registered by $(win.eventdata.image): $(win.eventdata.targetObject) = $(win.eventdata.details), user $(win.eventdata.user).</description>
    <mitre><id>T1546.009</id></mitre>
    <group>sysmon,attack,persistence,privilege_escalation,event_triggered_execution,registry,appcert_dlls,</group>
  </rule>

  <!-- Optional process precursor from PT-CR-1349. -->
  <rule id="110322" level="5">
    <if_sid>61603</if_sid>
    <field name="win.eventdata.commandLine" type="pcre2">(?i)\\Control\\Session Manager\\AppCertDlls</field>
    <description>Process command line references the AppCertDlls registry path.</description>
    <options>no_log</options>
    <group>sysmon,appcert_dlls,</group>
  </rule>

  <!-- Same PID writes AppCert after referencing the path within 30 seconds. -->
  <rule id="110323" level="13" frequency="1" timeframe="30">
    <if_sid>110321</if_sid>
    <if_matched_sid>110322</if_matched_sid>
    <same_location />
    <same_field>win.eventdata.processId</same_field>
    <description>High-confidence AppCert DLL persistence: process $(win.eventdata.image) registered $(win.eventdata.details) after referencing AppCertDlls.</description>
    <mitre><id>T1546.009</id></mitre>
    <group>sysmon,attack,persistence,privilege_escalation,event_triggered_execution,registry,appcert_dlls,</group>
  </rule>

</group>
