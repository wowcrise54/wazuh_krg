<!--
  Native Wazuh port of MaxPatrol SIEM PT-CR-664 /
  Default_File_Association_Modify. MITRE ATT&CK T1546.001.
  Data source: Microsoft Sysmon Event ID 13 (Registry value set).
-->
<group name="windows,default_file_association,t1546_001,">

  <!-- Internal selector for the four registry branches in PT-CR-664. -->
  <rule id="110280" level="0" noalert="1">
    <if_sid>61615</if_sid>
    <field name="win.eventdata.targetObject" type="pcre2">(?i)(?:\\shell\\open\\command\\|\\Software\\Classes\\\.[^\\]+\\\(Default\)$|\\Software\\Microsoft\\Windows\\CurrentVersion\\Explorer\\FileExts\\\.[^\\]+\\OpenWithProgids\\[^\\]+$|\\Software\\Microsoft\\Windows\\CurrentVersion\\Explorer\\FileExts\\\.[^\\]+\\UserChoice\\ProgId$)</field>
    <description>Default file association registry candidate.</description>
    <group>sysmon,registry,</group>
  </rule>

  <!-- Suspicious handler from the source rule: cmd.exe or PowerShell. -->
  <rule id="110281" level="12">
    <if_sid>110280</if_sid>
    <field name="win.eventdata.details" type="pcre2">(?i)(?:cmd|powershell(?:_ise)?)\.exe\b</field>
    <description>Suspicious default file handler configured by $(win.eventdata.image): $(win.eventdata.targetObject) = $(win.eventdata.details), user $(win.eventdata.user).</description>
    <mitre><id>T1546.001</id></mitre>
    <group>sysmon,attack,persistence,privilege_escalation,event_triggered_execution,registry,file_association,</group>
  </rule>

  <!-- shell\open\command handler modification. -->
  <rule id="110282" level="10">
    <if_sid>110280</if_sid>
    <field name="win.eventdata.targetObject" type="pcre2">(?i)\\shell\\open\\command\\</field>
    <field name="win.eventdata.details" type="pcre2" negate="yes">(?i)(?:cmd|powershell(?:_ise)?)\.exe\b</field>
    <description>File association open command modified by $(win.eventdata.image): $(win.eventdata.targetObject) = $(win.eventdata.details).</description>
    <mitre><id>T1546.001</id></mitre>
    <group>sysmon,attack,persistence,event_triggered_execution,registry,file_association,</group>
  </rule>

  <!-- Default ProgID assigned below Software\Classes\.extension. -->
  <rule id="110283" level="7">
    <if_sid>110280</if_sid>
    <field name="win.eventdata.targetObject" type="pcre2">(?i)\\Software\\Classes\\\.[^\\]+\\\(Default\)$</field>
    <field name="win.eventdata.details" type="pcre2" negate="yes">(?i)(?:cmd|powershell(?:_ise)?)\.exe\b</field>
    <description>Default file association ProgID modified by $(win.eventdata.image): $(win.eventdata.targetObject) = $(win.eventdata.details).</description>
    <mitre><id>T1546.001</id></mitre>
    <group>sysmon,attack,persistence,event_triggered_execution,registry,file_association,</group>
  </rule>

  <!-- Program added to OpenWithProgids; Explorer is excluded as in PT-CR-664. -->
  <rule id="110284" level="7">
    <if_sid>110280</if_sid>
    <field name="win.eventdata.targetObject" type="pcre2">(?i)\\FileExts\\\.[^\\]+\\OpenWithProgids\\[^\\]+$</field>
    <field name="win.eventdata.image" type="pcre2" negate="yes">(?i)\\explorer\.exe$</field>
    <field name="win.eventdata.details" type="pcre2" negate="yes">(?i)(?:cmd|powershell(?:_ise)?)\.exe\b</field>
    <description>Program added to file association OpenWithProgids by $(win.eventdata.image): $(win.eventdata.targetObject).</description>
    <mitre><id>T1546.001</id></mitre>
    <group>sysmon,attack,persistence,event_triggered_execution,registry,file_association,</group>
  </rule>

  <!-- UserChoice\ProgId selects the current per-user default application. -->
  <rule id="110285" level="7">
    <if_sid>110280</if_sid>
    <field name="win.eventdata.targetObject" type="pcre2">(?i)\\FileExts\\\.[^\\]+\\UserChoice\\ProgId$</field>
    <field name="win.eventdata.details" type="pcre2" negate="yes">(?i)(?:cmd|powershell(?:_ise)?)\.exe\b</field>
    <description>Per-user default file handler changed by $(win.eventdata.image): $(win.eventdata.targetObject) = $(win.eventdata.details).</description>
    <mitre><id>T1546.001</id></mitre>
    <group>sysmon,attack,persistence,event_triggered_execution,registry,file_association,</group>
  </rule>

</group>
