<!--
  Wazuh-native port of MP SIEM External Remote Services rules.

  Covered source rules:
    PT-CR-1787 MFA_Abnormal_Access
    PT-CR-1783 Owa_Abnormal_Access
    PT-CR-472  External_VPN_Service_Usage
    PT-CR-427  Connect_To_Significant_Hosts_From_VPN
    PT-CR-1036 Mail_Abnormal_Access
    PT-CR-1937 SMB_RPC_Internet_Connection
    PT-CR-1056 VPN_MultiUser_IP
    PT-CR-2653 Duplicate_Remote_Session

  PT-CR-1058, PT-CR-1048 and PT-CR-1055 are not present in the local
  knowledgebase_2025_04_10 export and are therefore not implemented here.
-->
<group name="external_remote_services_t1133,">

  <!-- PT-CR-472: External_VPN_Service_Usage. -->
  <rule id="110400" level="0" noalert="1">
    <decoded_as>json</decoded_as>
    <field name="protocol" type="pcre2">(?i)^esp$</field>
    <field name="action" type="pcre2">(?i)^(?:open|allow|detect)$</field>
    <field name="object" type="pcre2">(?i)^(?:connection|translation|packet|flow)$</field>
    <field name="status" type="pcre2">(?i)^success$</field>
    <field name="src.ip" type="pcre2">^\S+$</field>
    <field name="dst.ip" type="pcre2">^\S+$</field>
    <field name="dst.ip" type="pcre2" negate="yes">^(?:10\.|127\.|169\.254\.|172\.(?:1[6-9]|2[0-9]|3[0-1])\.|192\.168\.|0\.|255\.255\.255\.255|::1$|f[cd][0-9a-f]{2}:|fe80:)</field>
    <description>External VPN service selector: ESP tunnel.</description>
    <group>external_vpn_service_usage_selector,network,</group>
  </rule>

  <rule id="110401" level="0" noalert="1">
    <decoded_as>json</decoded_as>
    <field name="protocol" type="pcre2">(?i)^udp$</field>
    <field name="dst.port" type="pcre2">^(?:500|1194|1701|4500)$</field>
    <field name="action" type="pcre2">(?i)^(?:open|allow|detect)$</field>
    <field name="object" type="pcre2">(?i)^(?:connection|translation|packet|flow)$</field>
    <field name="status" type="pcre2">(?i)^success$</field>
    <field name="src.ip" type="pcre2">^\S+$</field>
    <field name="dst.ip" type="pcre2">^\S+$</field>
    <field name="dst.ip" type="pcre2" negate="yes">^(?:10\.|127\.|169\.254\.|172\.(?:1[6-9]|2[0-9]|3[0-1])\.|192\.168\.|0\.|255\.255\.255\.255|::1$|f[cd][0-9a-f]{2}:|fe80:)</field>
    <description>External VPN service selector: UDP VPN port.</description>
    <group>external_vpn_service_usage_selector,network,</group>
  </rule>

  <rule id="110402" level="0" noalert="1">
    <decoded_as>json</decoded_as>
    <field name="protocol" type="pcre2">(?i)^tcp$</field>
    <field name="dst.port" type="pcre2">^1723$</field>
    <field name="action" type="pcre2">(?i)^(?:open|allow|detect)$</field>
    <field name="object" type="pcre2">(?i)^(?:connection|translation|packet|flow)$</field>
    <field name="status" type="pcre2">(?i)^success$</field>
    <field name="src.ip" type="pcre2">^\S+$</field>
    <field name="dst.ip" type="pcre2">^\S+$</field>
    <field name="dst.ip" type="pcre2" negate="yes">^(?:10\.|127\.|169\.254\.|172\.(?:1[6-9]|2[0-9]|3[0-1])\.|192\.168\.|0\.|255\.255\.255\.255|::1$|f[cd][0-9a-f]{2}:|fe80:)</field>
    <description>External VPN service selector: PPTP.</description>
    <group>external_vpn_service_usage_selector,network,</group>
  </rule>

  <rule id="110403" level="10">
    <if_sid>110400,110401,110402</if_sid>
    <description>PT-CR-472 External VPN service usage from $(src.ip) to $(dst.ip):$(dst.port).</description>
    <mitre>
      <id>T1133</id>
    </mitre>
    <group>attack,initial_access,external_remote_services,external_vpn_service_usage,network,</group>
  </rule>

  <!-- PT-CR-1937: SMB_RPC_Internet_Connection. -->
  <rule id="110410" level="0" noalert="1">
    <if_sid>61605</if_sid>
    <field name="win.eventdata.destinationPort" type="pcre2">^(?:135|139|445)$</field>
    <field name="win.eventdata.destinationIp" type="pcre2" negate="yes">^(?:10\.|127\.|169\.254\.|172\.(?:1[6-9]|2[0-9]|3[0-1])\.|192\.168\.|0\.|255\.255\.255\.255|::1$|f[cd][0-9a-f]{2}:|fe80:)</field>
    <description>SMB/RPC external connection selector: Sysmon destination is external.</description>
    <group>smb_rpc_internet_connection_selector,sysmon,</group>
  </rule>

  <rule id="110411" level="0" noalert="1">
    <if_sid>61605</if_sid>
    <field name="win.eventdata.destinationPort" type="pcre2">^(?:135|139|445)$</field>
    <field name="win.eventdata.sourceIp" type="pcre2" negate="yes">^(?:10\.|127\.|169\.254\.|172\.(?:1[6-9]|2[0-9]|3[0-1])\.|192\.168\.|0\.|255\.255\.255\.255|::1$|f[cd][0-9a-f]{2}:|fe80:)</field>
    <description>SMB/RPC external connection selector: Sysmon source is external.</description>
    <group>smb_rpc_internet_connection_selector,sysmon,</group>
  </rule>

  <rule id="110412" level="0" noalert="1">
    <if_sid>60103</if_sid>
    <field name="win.system.eventID">^5156$</field>
    <field name="win.eventdata.destinationPort" type="pcre2">^(?:135|139|445)$</field>
    <field name="win.eventdata.destinationAddress" type="pcre2" negate="yes">^(?:10\.|127\.|169\.254\.|172\.(?:1[6-9]|2[0-9]|3[0-1])\.|192\.168\.|0\.|255\.255\.255\.255|::1$|f[cd][0-9a-f]{2}:|fe80:)</field>
    <description>SMB/RPC external connection selector: Windows 5156 destination is external.</description>
    <group>smb_rpc_internet_connection_selector,windows_security,</group>
  </rule>

  <rule id="110413" level="0" noalert="1">
    <if_sid>60103</if_sid>
    <field name="win.system.eventID">^5156$</field>
    <field name="win.eventdata.destinationPort" type="pcre2">^(?:135|139|445)$</field>
    <field name="win.eventdata.sourceAddress" type="pcre2" negate="yes">^(?:10\.|127\.|169\.254\.|172\.(?:1[6-9]|2[0-9]|3[0-1])\.|192\.168\.|0\.|255\.255\.255\.255|::1$|f[cd][0-9a-f]{2}:|fe80:)</field>
    <description>SMB/RPC external connection selector: Windows 5156 source is external.</description>
    <group>smb_rpc_internet_connection_selector,windows_security,</group>
  </rule>

  <rule id="110414" level="10">
    <if_sid>110410,110411,110412,110413</if_sid>
    <description>PT-CR-1937 SMB/RPC connection involving an external address.</description>
    <mitre>
      <id>T1133</id>
    </mitre>
    <group>attack,initial_access,external_remote_services,smb_rpc_internet_connection,network,</group>
  </rule>

  <!-- PT-CR-1783: Owa_Abnormal_Access. -->
  <rule id="110420" level="0" noalert="1">
    <decoded_as>json</decoded_as>
    <field name="event_src.title" type="pcre2">(?i)^internet_information_services$</field>
    <field name="action" type="pcre2">(?i)^access$</field>
    <field name="status" type="pcre2">(?i)^success$</field>
    <field name="subject.account.id" type="pcre2">^\S+$</field>
    <field name="object.path" type="pcre2">(?i)^/owa/default\.aspx$</field>
    <field name="external_src.host" type="pcre2">^\S+$</field>
    <description>OWA successful access selector: normalized JSON.</description>
    <group>owa_abnormal_access_selector,web,exchange,</group>
  </rule>

  <rule id="110421" level="6">
    <if_sid>110420</if_sid>
    <description>PT-CR-1783 Successful OWA access for $(subject.account.id) from $(external_src.host).</description>
    <mitre>
      <id>T1133</id>
    </mitre>
    <group>attack,initial_access,external_remote_services,owa_abnormal_access,web,exchange,</group>
  </rule>

  <rule id="110422" level="6">
    <url type="pcre2">(?i)^/owa/default\.aspx(?:\?|$)</url>
    <status type="pcre2">^(?:2|3)[0-9]{2}$</status>
    <user type="pcre2">^(?!-|anonymous$).+</user>
    <field name="srcip" type="pcre2" negate="yes">^(?:10\.|127\.|169\.254\.|172\.(?:1[6-9]|2[0-9]|3[0-1])\.|192\.168\.|0\.|255\.255\.255\.255)$</field>
    <description>PT-CR-1783 Successful OWA access for $(user) from $(srcip).</description>
    <mitre>
      <id>T1133</id>
    </mitre>
    <group>attack,initial_access,external_remote_services,owa_abnormal_access,web,exchange,</group>
  </rule>

  <!-- PT-CR-1036: Mail_Abnormal_Access. -->
  <rule id="110430" level="0" noalert="1">
    <decoded_as>json</decoded_as>
    <field name="event_src.title" type="pcre2">(?i)^internet_information_services$</field>
    <field name="object.path" type="pcre2">(?i)microsoft-server-activesync</field>
    <field name="object.name" type="pcre2">(?i)^default\.eas$</field>
    <field name="object.value" type="pcre2">(?i)^post$</field>
    <field name="subject.account.name" type="pcre2">^\S+$</field>
    <field name="datafield1" type="pcre2" negate="yes">(?i)^(?:amprobe/local/clientaccess|testactivesyncconnectivity)$</field>
    <field name="object.fullpath" type="pcre2">(?i)deviceid=[0-9a-z]+&amp;</field>
    <description>Exchange ActiveSync successful access selector: normalized JSON.</description>
    <group>mail_abnormal_access_selector,web,exchange,</group>
  </rule>

  <rule id="110431" level="8">
    <if_sid>110430</if_sid>
    <description>PT-CR-1036 Successful Exchange ActiveSync access for $(subject.account.name) from $(external_src.host), request $(object.fullpath).</description>
    <mitre>
      <id>T1133</id>
    </mitre>
    <group>attack,initial_access,external_remote_services,mail_abnormal_access,web,exchange,</group>
  </rule>

  <rule id="110432" level="8">
    <url type="pcre2">(?i)microsoft-server-activesync.*deviceid=[0-9a-z]+</url>
    <field name="method" type="pcre2">(?i)^post$</field>
    <status type="pcre2">^(?:2|3)[0-9]{2}$</status>
    <user type="pcre2">^(?!-|anonymous$|amprobe/local/clientaccess$|testactivesyncconnectivity$).+</user>
    <field name="srcip" type="pcre2" negate="yes">^(?:10\.|127\.|169\.254\.|172\.(?:1[6-9]|2[0-9]|3[0-1])\.|192\.168\.|0\.|255\.255\.255\.255)$</field>
    <description>PT-CR-1036 Successful Exchange ActiveSync access for $(user) from $(srcip).</description>
    <mitre>
      <id>T1133</id>
    </mitre>
    <group>attack,initial_access,external_remote_services,mail_abnormal_access,web,exchange,</group>
  </rule>

  <!-- PT-CR-1787: MFA_Abnormal_Access. -->
  <rule id="110440" level="7">
    <decoded_as>json</decoded_as>
    <field name="event_src.title" type="pcre2">(?i)^multifactor$</field>
    <field name="action" type="pcre2">(?i)^receive$</field>
    <field name="status" type="pcre2">(?i)^success$</field>
    <field name="object" type="pcre2">(?i)^request$</field>
    <field name="object.type" type="pcre2">(?i)response</field>
    <field name="object.account.name" type="pcre2">^\S+$</field>
    <field name="external_src.ip" type="pcre2">^\S+$</field>
    <field name="datafield5" type="pcre2">^\S+</field>
    <description>PT-CR-1787 Successful MFA response for $(object.account.name) from $(external_src.ip) using device $(datafield5).</description>
    <mitre>
      <id>T1133</id>
    </mitre>
    <group>attack,initial_access,external_remote_services,mfa_abnormal_access,mfa,</group>
  </rule>

  <rule id="110441" level="10" frequency="3" timeframe="900">
    <if_matched_sid>110440</if_matched_sid>
    <same_field>object.account.name</same_field>
    <different_field>external_src.ip</different_field>
    <description>PT-CR-1787 Multiple successful MFA responses for $(object.account.name) from different external IPs within 15 minutes.</description>
    <mitre>
      <id>T1133</id>
    </mitre>
    <group>attack,initial_access,external_remote_services,mfa_abnormal_access,mfa,</group>
  </rule>

  <!-- PT-CR-1056: VPN_MultiUser_IP. Level 1 + no_log is required for if_matched_sid. -->
  <rule id="110450" level="1">
    <decoded_as>json</decoded_as>
    <field name="event_src.title" type="pcre2">(?i)(?:vpn|remote_access|remote-access)</field>
    <field name="status" type="pcre2">(?i)^success$</field>
    <field name="src.ip" type="pcre2">^\S+$</field>
    <field name="subject.account.name" type="pcre2">^\S+$</field>
    <description>Successful VPN login selector with subject account.</description>
    <options>no_log</options>
    <group>vpn_success_subject_selector,vpn,</group>
  </rule>

  <rule id="110451" level="1">
    <decoded_as>json</decoded_as>
    <field name="event_src.title" type="pcre2">(?i)(?:vpn|remote_access|remote-access)</field>
    <field name="status" type="pcre2">(?i)^success$</field>
    <field name="src.ip" type="pcre2">^\S+$</field>
    <field name="object.account.name" type="pcre2">^\S+$</field>
    <description>Successful VPN login selector with object account.</description>
    <options>no_log</options>
    <group>vpn_success_object_selector,vpn,</group>
  </rule>

  <rule id="110452" level="10" frequency="2" timeframe="3600">
    <if_matched_sid>110450</if_matched_sid>
    <same_field>src.ip</same_field>
    <different_field>subject.account.name</different_field>
    <description>PT-CR-1056 Multiple VPN users authenticated from the same external IP $(src.ip) within one hour.</description>
    <mitre>
      <id>T1133</id>
    </mitre>
    <group>attack,initial_access,external_remote_services,vpn_multiuser_ip,vpn,</group>
  </rule>

  <rule id="110453" level="10" frequency="2" timeframe="3600">
    <if_matched_sid>110451</if_matched_sid>
    <same_field>src.ip</same_field>
    <different_field>object.account.name</different_field>
    <description>PT-CR-1056 Multiple VPN users authenticated from the same external IP $(src.ip) within one hour.</description>
    <mitre>
      <id>T1133</id>
    </mitre>
    <group>attack,initial_access,external_remote_services,vpn_multiuser_ip,vpn,</group>
  </rule>

  <!-- PT-CR-2653: Duplicate_Remote_Session. -->
  <rule id="110460" level="8">
    <decoded_as>json</decoded_as>
    <field name="object.type" type="pcre2">(?i)^duplicated$</field>
    <field name="status" type="pcre2">(?i)^success$</field>
    <field name="event_src.title" type="pcre2">(?i)^(?:windows|.*vpn.*|remote_access|remote-access)$</field>
    <description>PT-CR-2653 Duplicate remote session for $(subject.account.name) from $(src.ip).</description>
    <mitre>
      <id>T1133</id>
    </mitre>
    <group>attack,initial_access,external_remote_services,duplicate_remote_session,vpn,remote_session,</group>
  </rule>

  <!-- PT-CR-427: Connect_To_Significant_Hosts_From_VPN. Requires local CDB lists. -->
  <rule id="110470" level="0" noalert="1">
    <decoded_as>json</decoded_as>
    <field name="object" type="pcre2">(?i)^(?:connection|translation|flow|session)$</field>
    <field name="action" type="pcre2">(?i)^(?:allow|detect|open|start)$</field>
    <field name="status" type="pcre2">(?i)^success$</field>
    <field name="src.ip" type="pcre2">^\S+$</field>
    <field name="dst.ip" type="pcre2">^\S+$</field>
    <list field="src.ip" lookup="address_match_key">etc/lists/vpn-networks</list>
    <list field="dst.ip" lookup="address_match_key">etc/lists/significant-networks</list>
    <list field="dst.ip" lookup="not_address_match_key">etc/lists/significant-hosts-whitelist</list>
    <description>VPN source to significant destination selector.</description>
    <group>connect_to_significant_hosts_from_vpn_selector,network,vpn,</group>
  </rule>

  <rule id="110471" level="8">
    <if_sid>110470</if_sid>
    <description>PT-CR-427 Connection from VPN pool $(src.ip) to significant destination $(dst.ip):$(dst.port).</description>
    <mitre>
      <id>T1133</id>
    </mitre>
    <group>attack,initial_access,external_remote_services,connect_to_significant_hosts_from_vpn,vpn,network,</group>
  </rule>

</group>
