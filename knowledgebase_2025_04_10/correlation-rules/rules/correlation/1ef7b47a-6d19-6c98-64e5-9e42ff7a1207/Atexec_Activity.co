query GetBase64Regex() from Generic_Regexes {
    column::regex_type == "base64"
}

event Task_Created:
    key:
        event_src.host
    filter {
        in_list(["Remote_Code_Execution_Via_AtSvc", "Scheduled_Task_Was_Created_Or_Updated_Via_Schtasks"], correlation_name)
        and object.name != null   
        and filter::CheckWL_Tasks("Atexec_Activity", lower(join([subject.account.name, object.name], "|")))
    }

event Powershell_Executed_Or_Impacket_Like_Execution:
    key:
        event_src.host
    filter {
        in_list(["Execute_Encoded_Powershell", "Remote_Execution_Via_Custom_Impacket"], correlation_name)
        and regex(lower(object.process.parent.cmdline), "-k\s+netsvcs\s+-p\s+-s\s+schedule", 0) != null
    }

rule Atexec_Activity: (Task_Created and Powershell_Executed_Or_Impacket_Like_Execution) within 10s
    
    init {
        $labels = "w_auto|CheckWL_Tasks"
    }
    
    on Task_Created {
        $subject.account.name = subject.account.name
        $subject.account.fullname = subject.account.fullname
        $subject.account.domain = subject.account.domain
        $subject.account.session_id = subject.account.session_id
        $subject.account.id = subject.account.id
        $subject.account.privileges = subject.account.privileges

        $subject.process.id = subject.process.id
        $subject.process.parent.id = subject.process.parent.id
        $subject.process.guid = subject.process.guid

        $object.name = object.name
        $object.property = object.property
        $object.value = object.value
        $object.type = object.type
        $object.state = object.state
        $object.vendor = object.vendor

        $src.asset = src.asset
        $src.host = src.host
        $src.ip = src.ip
        $src.hostname = src.hostname
        $src.fqdn = src.fqdn
        $src.port = src.port

        $dst.asset = dst.asset
        $dst.host = dst.host
        $dst.ip = dst.ip
        $dst.hostname = dst.hostname
        $dst.fqdn = dst.fqdn
        $dst.port = dst.port

        $logon_type = logon_type
        $logon_service = logon_service
        $logon_auth_method = logon_auth_method

        $chain_id = chain_id

        $alert.key = lower(join([subject.account.name, object.name], "|"))
    }

    on Powershell_Executed_Or_Impacket_Like_Execution {
        $object.process.id = object.process.id
        $object.process.name = object.process.name
        $object.process.path = object.process.path
        $object.process.fullpath = object.process.fullpath
        $object.process.hash = object.process.hash
        $object.process.hash.md5 = object.process.hash.md5
        $object.process.hash.sha1 = object.process.hash.sha1
        $object.process.hash.sha256 = object.process.hash.sha256
        $object.process.version = object.process.version
        $object.process.cmdline = object.process.cmdline
        $object.process.guid = object.process.guid
        $object.process.meta = object.process.meta
        $object.process.original_name = object.process.original_name
        $object.process.cwd = object.process.cwd
        $object.process.chain = object.process.chain
        
        $object.process.parent.id = object.process.parent.id
        $object.process.parent.name = object.process.parent.name
        $object.process.parent.path = object.process.parent.path
        $object.process.parent.fullpath = object.process.parent.fullpath
        $object.process.parent.cmdline = object.process.parent.cmdline

        $event_src.host = event_src.host
        $event_src.fqdn = event_src.fqdn
        $event_src.hostname = event_src.hostname
        $event_src.ip = event_src.ip
        $event_src.asset = event_src.asset
        $event_src.vendor = event_src.vendor
        $event_src.title = event_src.title
        $event_src.subsys = event_src.subsys
        $event_src.category = event_src.category
        $event_src.rule = event_src.rule

        $base64_pattern = select_query_first("GetBase64Regex", [], "regex_value")

        $raw_base64 = regex(object.process.cmdline, $base64_pattern, 1)

        if $raw_base64 != null then
            $reason = "Base64 Encoded Value"
            $detect = decode(buffer_from_base64($raw_base64), "UTF-8")

            if find_substr($detect, "\u0000") != null and find_substr($detect, "�") == null then
                $detect = decode(buffer_from_base64($raw_base64), "UCS2-LE")
            endif

            if find_substr($detect, "\u0000") != null or find_substr($detect, "�") != null then
                $reason = "Invalid base64 value"
                $detect = null
            endif
        endif

        $datafield1 = coalesce(regex(lower($detect), "\$folder\.gettask\(\\\"(.*)\\\"\)", 1), 
            regex(lower(object.process.cmdline), "(\\\\\\\\127\.0\.0\.1\\\\(c|admin)\$\\\\|.:\\\\windows\\\\temp\\\\)(\S+)\.\S+\s*2\^?>", 3))

        if $detect != null then
            $object.process.decoded_data = $detect

            $labels = $labels + "|obj_proc_decoded_data_enriched"
        endif
    }

emit {
    $correlation_type = "incident"

    if lower($object.name) != $datafield1 then
        $detect = "drop"
    endif

    $subject = "account"
    $action = "create"
    $object = "task"
    $status = "success"

    $importance = "medium"

    $category.generic = "Attack"
    $category.high = "Execution"
    $category.low = "Scheduled Task/Job"
    
    $incident.aggregation.key = join([$correlation_name, $event_src.host, $subject.account.id], "|")
    $incident.severity = $importance
    $incident.category = "HackToolsDetection"
    $incident.aggregation.timeout = 2h
}
