event Rubeus_In_Commandline:
    key: 
        event_src.host
    filter {
        filter::NotFromCorrelator()
        and filter::ProcessStart_Windows_any()
        and (
            lower(object.process.original_name) == "rubeus.exe"
            or lower(object.process.meta) == "description:rubeus | product:rubeus | company:"
            or lower(object.process.name) == "rubeus.exe"
            or (
                regex(lower(object.process.cmdline), "\sasktgt\\b.*?\/(user|password):", 0) != null
                or regex(lower(object.process.cmdline), "\sasktgs\s.*?\/(service|ticket):", 0) != null
                or regex(lower(object.process.cmdline), "\sptt\s.*?\/ticket:", 0) != null
                or regex(lower(object.process.cmdline), "\screatenetonly\s.*?\/program:", 0) != null
                or regex(lower(object.process.cmdline), "\ss4u\s.*?\/((impersonate)?user|ticket|tgs|msdsspn):", 0) != null
                or regex(lower(object.process.cmdline), "\sdescribe\s.*?\/ticket:", 0) != null
                or regex(lower(object.process.cmdline), "\schangepw\s.*?\/(ticket|new):", 0) != null
                or regex(lower(object.process.cmdline), "\stgssub\s.*?\/(ticket|altservice):", 0) != null
                or regex(lower(object.process.cmdline), "\s(golden|silver)\s.*?\/(user|service):", 0) != null
                or regex(lower(object.process.cmdline), "\sbrute\s.*?\/password(s)?:", 0) != null
                or regex(lower(object.process.cmdline), "\srenew\s.*?\/ticket:", 0) != null
                or regex(lower(object.process.cmdline), "\shash\s.*?\/password:", 0) != null
                or regex(lower(object.process.cmdline), "\s(kerberoast|asreproast|tgtdeleg|harvest|klist|triage)(\s|$)", 0) != null
                or regex(lower(object.process.cmdline), "\smonitor($|\s.*?\/(interval|targetuser|runfor|nowrap)\\b)", 0) != null
                # purge
                or regex(lower(object.process.cmdline), "^(\\\"|\.)?[:\w\s\\\]+(\.exe)?(\\\")?\s+purge(\s+\/luid:\S+)?\s*$", 0) != null
                # dump
                or regex(lower(object.process.cmdline), "^(\\\"|\.)?[:\w\s\\\]+(\.exe)?(\\\")?\s+dump((\s+\/(((luid|service|user):\w+)|(server:((((\d+\.){3}\d+|(\w+\.)+\w+)(:\d+)?)))|nowrap))+)?\s*$", 0) != null
            )
        )
        and length(object.process.cmdline) <= 150
        and regex(lower(object.process.fullpath), "\w:\\\\windows\\\\system32\\\\klist.exe", 0) == null
        and filter::CheckWL_Process_Creation("Rubeus_Usage", lower(object.process.cmdline))
    }
 
event Rubeus_In_PowerShell_Pipeline:
    key:
        event_src.host
    filter {
        filter::NotFromCorrelator()
        and msgid == "4103"
        and action == "execute"
        and object == "command"
        and event_src.title == "windows"
        and (
            regex(lower(object.process.cmdline), "\sasktgt\\b.*?\/(user|password):", 0) != null
            or regex(lower(object.process.cmdline), "\sasktgs\s.*?\/(service|ticket):", 0) != null
            or regex(lower(object.process.cmdline), "\sptt\s.*?\/ticket:", 0) != null
            or regex(lower(object.process.cmdline), "\screatenetonly\s.*?\/program:", 0) != null
            or regex(lower(object.process.cmdline), "\ss4u\s.*?\/((impersonate)?user|ticket|tgs|msdsspn):", 0) != null
            or regex(lower(object.process.cmdline), "\sdescribe\s.*?\/ticket:", 0) != null
            or regex(lower(object.process.cmdline), "\schangepw\s.*?\/(ticket|new):", 0) != null
            or regex(lower(object.process.cmdline), "\stgssub\s.*?\/(ticket|altservice):", 0) != null
            or regex(lower(object.process.cmdline), "\s(golden|silver)\s.*?\/(user|service):", 0) != null
            or regex(lower(object.process.cmdline), "\sbrute\s.*?\/password(s)?:", 0) != null
            or regex(lower(object.process.cmdline), "\srenew\s.*?\/ticket:", 0) != null
            or regex(lower(object.process.cmdline), "\shash\s.*?\/password:", 0) != null
            or regex(lower(object.process.cmdline), "\s(kerberoast|asreproast|tgtdeleg|harvest|klist|triage)(\s|([\'\"]+)?$)", 0) != null
            or regex(lower(object.process.cmdline), "\smonitor($|\s.*?\/(interval|targetuser|runfor|nowrap)\\b)", 0) != null
            or regex(lower(object.process.cmdline), "::writeallbytes.*?\\bticket\.kirbi\\b.*?frombase64", 0) != null
            # purge
            or regex(lower(object.process.cmdline), "^(\\\"|\.)?[:\w\s\\\]+(\.exe)?(\\\")?\s+purge(\s+\/luid:\S+)?\s*$", 0) != null
            # dump
            or regex(lower(object.process.cmdline), "^(\\\"|\.)?[:\w\s\\\]+(\.exe)?(\\\")?\s+dump((\s+\/(((luid|service|user):\w+)|(server:((((\d+\.){3}\d+|(\w+\.)+\w+)(:\d+)?)))|nowrap))+)?\s*$", 0) != null
        )
        and length(object.process.cmdline) <= 150
        and filter::CheckWL_Powershell("Rubeus_Usage", lower(object.process.cmdline))
    }

event Rubeus_In_PowerShell_Command:
    key:
        event_src.host
    filter {
        filter::NotFromCorrelator()
        and msgid == "4104"
        and action == "execute"
        and object == "command"
        and event_src.title == "windows"
        and (
            regex(lower(object.process.cmdline), "\sasktgt\\b.*?\/(user|password):", 0) != null
            or regex(lower(object.process.cmdline), "\sasktgs\s.*?\/(service|ticket):", 0) != null
            or regex(lower(object.process.cmdline), "\sptt\s.*?\/ticket:", 0) != null
