            or regex(lower(object.process.cmdline), "\ss4u\s.*?\/((impersonate)?user|ticket|tgs|msdsspn):", 0) != null
            or regex(lower(object.process.cmdline), "\sdescribe\s.*?\/ticket:", 0) != null
