event Remove_Or_Modify_Agent_Group:
    key:
        event_src.host, subject.account.id
    filter {
        filter::NotFromCorrelator()
        and event_src.title == "aria_operations_for_logs"
        and subject == "account"
        and in_list(["modify", "remove"], action)
        and object == "configuration"
        and object.type == "agent group configuration"
        and filter::CheckWL_Specific_Only(
            "AOFL_Massive_Change_Agent_Groups", 
            lower(join([event_src.host, subject.account.id],"|"))
        )
    }

rule AOFL_Massive_Change_Agent_Groups: Remove_Or_Modify_Agent_Group[5,] timer 5m

    init {
        $labels = "w_auto|CheckWL_Specific_Only"
        $remove_agent_group = []
        $modify_agent_group = []
    }
    
    on Remove_Or_Modify_Agent_Group {
        $subject = subject
        $action = action
        $object = object
        $status = status
        
        $subject.account.id = subject.account.id
        $subject.account.name = subject.account.name
        $subject.account.fullname = subject.account.fullname
        $subject.account.domain = subject.account.domain
        $subject.account.session_id = subject.account.session_id
        $subject.account.privileges = subject.account.privileges
        $subject.account.provider = subject.account.provider
        
        $object.type = object.type
        
        if action == "modify" then
            $modify_agent_group = append($modify_agent_group, object.name)
        endif
        
        if action == "remove" then
            $remove_agent_group = append($remove_agent_group, object.name)
        endif
        
        $dst.asset = dst.asset
        $dst.host = dst.host
        $dst.ip = dst.ip
        $dst.hostname = dst.hostname
        $dst.fqdn = dst.fqdn
        $dst.port = dst.port
        $dst.mac = dst.mac
        
        $logon_service = logon_service
    
        $event_src.host = event_src.host
        $event_src.fqdn = event_src.fqdn
        $event_src.hostname = event_src.hostname
        $event_src.ip = event_src.ip
        $event_src.asset = event_src.asset
        $event_src.vendor = event_src.vendor
        $event_src.title = event_src.title
        $event_src.subsys = event_src.subsys
        $event_src.category = event_src.category
        $event_src.rule = event_src.rule
    }

emit {
    $correlation_type = "event"
    
    if length($remove_agent_group) > 0 then
        $datafield1 = join($remove_agent_group, ",")    # Removed groups
    endif
    
    if length($modify_agent_group) > 0 then 
        $datafield2 = join($modify_agent_group, ",")    # Modified groups
    endif

    $importance = "medium"
    
    $alert.key = lower(join([$event_src.host, $subject.account.id],"|"))
    if $datafield1 != null and $datafield2 != null then
        $alert.context = "Removed agent groups: " + $datafield1 + ", Modified agent groups: " + $datafield2
    elif $datafield1 != null then
        $alert.context = "Removed agent groups: " + $datafield1
    elif $datafield2 != null then
        $alert.context = "Modified agent groups: " + $datafield2
    endif

    $category.generic = "Attack"
    $category.high = "Defense Evasion"
    $category.low = "Impair Defenses: Disable or Modify Tools"
    
    $incident.aggregation.key = join([$correlation_name, $alert.key], "|")
    $incident.severity = $importance
    $incident.category = "ProtectionBypassing"
    $incident.aggregation.timeout = 2h
}