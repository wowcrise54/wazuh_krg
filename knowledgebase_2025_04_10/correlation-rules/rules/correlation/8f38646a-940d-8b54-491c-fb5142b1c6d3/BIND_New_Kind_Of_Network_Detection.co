query Check_Malicious_Domains($request) from Malicious_Domains {
    regex_match($request, column::pattern)
    and description == "New Kind of Network"
}

event NKN_Domain_Request:
    key:
        event_src.host
    filter {
        filter::NotFromCorrelator()
        and event_src.title == "bind"
        and object == "request"
        and action == "receive"
        # *.nkn.org
        and exec_query("Check_Malicious_Domains", [coalesce(datafield2, object.value)])
        and filter::CheckWL_Networking("BIND_New_Kind_Of_Network_Detection", lower(join([src.host, object.value], "|")))
    }

rule BIND_New_Kind_Of_Network_Detection: NKN_Domain_Request

    init {
        $labels = "w_auto|CheckWL_Networking"
    }

    on NKN_Domain_Request {
        $object.name = object.name
        $object.property = object.property
        $object.value = object.value
        $object.query = object.query

        $src.host = src.host
        $src.fqdn = src.fqdn
        $src.hostname = src.hostname
        $src.ip = src.ip
        $src.port = src.port
        $src.asset = src.asset

        $event_src.host = event_src.host
        $event_src.fqdn = event_src.fqdn
        $event_src.hostname = event_src.hostname
        $event_src.ip = event_src.ip
        $event_src.asset = event_src.asset
        $event_src.vendor = event_src.vendor
        $event_src.title = event_src.title
        $event_src.subsys = event_src.subsys
        $event_src.category = event_src.category

        $alert.key = lower(join([src.host, object.value], "|"))
    }

emit {
    $correlation_type = "incident"

    $action = "receive"
    $object = "request"
    $status = "success"

    $importance = "medium"

    $category.generic = "Attack"
    $category.high = "Command and Control"
    $category.low = "Application Layer Protocol: DNS"

    $incident.aggregation.key = join([$correlation_name, $src.host], "|")
    $incident.severity = $importance
    $incident.category = "BotNetCC"
    $incident.aggregation.timeout = 2h
}
