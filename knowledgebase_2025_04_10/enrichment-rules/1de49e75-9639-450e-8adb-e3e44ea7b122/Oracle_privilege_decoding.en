event Oracle_privilege_action:
    filter {
        in_list(["PT_Oracle_Oracle_Database_filemonitor_System_grant",
                 "PT_Oracle_Oracle_Database_filemonitor_System_revoke"], id)
    }

enrichment Oracle_privilege_decoding

    enrich Oracle_privilege_action:
        enrich_fields {
            object.name = switch object.id
                case "3" "ALTER SYSTEM"
                case "4" "AUDIT SYSTEM"
                case "5" "CREATE SESSION"
                case "6" "ALTER SESSION"
                case "7" "RESTRICTED SESSION"
                case "10" "CREATE TABLESPACE"
                case "11" "ALTER TABLESPACE"
                case "12" "MANAGE TABLESPACE"
                case "13" "DROP TABLESPACE"
                case "15" "UNLIMITED TABLESPACE"
                case "20" "CREATE USER"
                case "21" "BECOME USER"
                case "22" "ALTER USER"
                case "23" "DROP USER"
                case "30" "CREATE ROLLBACK SEGMENT"
                case "31" "ALTER ROLLBACK SEGMENT"
                case "32" "DROP ROLLBACK SEGMENT"
                case "40" "CREATE TABLE"
                case "41" "CREATE ANY TABLE"
                case "42" "ALTER ANY TABLE"
                case "43" "BACKUP ANY TABLE"
                case "44" "DROP ANY TABLE"
                case "45" "LOCK ANY TABLE"
                case "46" "COMMENT ANY TABLE"
                case "47" "SELECT ANY TABLE"
                case "48" "INSERT ANY TABLE"
                case "49" "UPDATE ANY TABLE"
