                case "317" "DROP ANY MEASURE FOLDER"
                case "318" "INSERT ANY MEASURE FOLDER"
                case "319" "CREATE CUBE BUILD PROCESS"
                case "320" "CREATE ANY CUBE BUILD PROCESS"
