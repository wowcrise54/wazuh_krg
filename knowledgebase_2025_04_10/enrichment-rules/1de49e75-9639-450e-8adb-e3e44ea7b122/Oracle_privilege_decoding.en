                case "83" "SYSDBA"
                case "84" "SYSOPER"
                case "85" "CREATE PUBLIC SYNONYM"
                case "86" "DROP PUBLIC SYNONYM"
                case "90" "CREATE VIEW"
                case "91" "CREATE ANY VIEW"
                case "92" "DROP ANY VIEW"
                case "105" "CREATE SEQUENCE"
                case "106" "CREATE ANY SEQUENCE"
                case "107" "ALTER ANY SEQUENCE"
                case "108" "DROP ANY SEQUENCE"
                case "109" "SELECT ANY SEQUENCE"
                case "115" "CREATE DATABASE LINK"
                case "120" "CREATE PUBLIC DATABASE LINK"
                case "121" "DROP PUBLIC DATABASE LINK"
                case "125" "CREATE ROLE"
                case "126" "DROP ANY ROLE"
