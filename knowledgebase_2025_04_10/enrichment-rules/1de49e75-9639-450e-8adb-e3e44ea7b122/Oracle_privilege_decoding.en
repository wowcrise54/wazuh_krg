                case "288" "EXECUTE ANY ASSEMBLY"
                case "289" "EXECUTE ASSEMBLY"
                case "290" "CREATE MINING MODEL"
                case "291" "CREATE ANY MINING MODEL"
                case "292" "DROP ANY MINING MODEL"
                case "293" "SELECT ANY MINING MODEL"
                case "294" "ALTER ANY MINING MODEL"
