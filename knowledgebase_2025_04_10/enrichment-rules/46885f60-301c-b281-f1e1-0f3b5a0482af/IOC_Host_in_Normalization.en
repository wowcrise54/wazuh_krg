enrich enrich_by_cmdline_info:
    enrich_fields {
        $ioc_info = exec_query("Get_host_info_regex", [regex(lower(object.process.cmdline), "(https?:\/\/|@)([a-z0-9-\.]+)(\/|:|\\b)", 2), regex(lower(object.process.cmdline),"\\b((25[0-5]|2[0-4][0-9]|[01]?[0-9][0-9]?)\.){3}(25[0-5]|2[0-4][0-9]|[01]?[0-9][0-9]?)\\b",0)])
       
       if $ioc_info["$value"] != null then
           if alert.ioc_value != null then
                alert.ioc_value = join([alert.ioc_value, $ioc_info["$value"]], " | ")
            else
                alert.ioc_value = $ioc_info["$value"]
            endif
           if alert.ioc_provider != null then
                alert.ioc_provider = join([alert.ioc_provider, "ioc:commandline"], " | ")
            else
                alert.ioc_provider = "local TL IOCs_Value | ioc:commandline"
            endif
            importance = switch importance
                case "info" "low"
                case "low" "medium"
                case "medium" "high"
            endswitch
        endif
    }    

