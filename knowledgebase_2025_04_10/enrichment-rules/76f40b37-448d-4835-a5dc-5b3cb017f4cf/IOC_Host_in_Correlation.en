enrich enrich_by_cmdline_info:
    enrich_fields {
        $ioc_info = exec_query("Get_host_info_regex", [regex(lower(object.process.cmdline), "(https?:\/\/|@)([a-z0-9-\.]+)(\/|:|\\b)", 2), regex(lower(object.process.cmdline),"\\b((25[0-5]|2[0-4][0-9]|[01]?[0-9][0-9]?)\.){3}(25[0-5]|2[0-4][0-9]|[01]?[0-9][0-9]?)\\b",0)])
        
        if $ioc_info["$value"] != null then
            alert.ioc_provider = "local TL IOCs_Value"
            alert.ioc_value = $ioc_info["$value"]
            alert.context = alert.context + " | ioc:commandline:" + alert.ioc_value
            
            # Escalate
            
            if correlation_type == "event" then
                correlation_type = "incident"
                
                if incident.aggregation.key == null then
                    incident.aggregation.key = join([correlation_name, event_src.host, subject.account.id], "|")
                endif
                
                if importance == "info" then
                    importance = "low"
                endif
                incident.severity = importance
                
                if incident.category == null then
                    incident.category = "Undefined"
                endif
                
                if incident.aggregation.timeout == null then
                    incident.aggregation.timeout = 2h
                endif
            endif
        endif
    }    

