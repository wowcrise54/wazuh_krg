filter LoginAttempt_Windows_Endpoint_All_Accounts() {
    filter::NotFromCorrelator()
    and event_src.title == "windows"
    and category.high == "Access Management"
    and category.low == "Communication"
    and action == "login"
    and event_src.vendor == "microsoft"
    and (
        filter::UserAccount_Windows(subject.account.name, subject.account.id)
        or filter::ComputerAccount_Windows(subject.account.name)
    )
    and dst.host != null
}
