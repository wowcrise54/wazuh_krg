filter CheckWL_WhiteListValue_4(string $rule_name, string $host, string $user, string $specific_value, string $specific_value_2, string $specific_value_3, string $specific_value_4) {
    table::Common_whitelist_value {
        (column::rule == $rule_name or column::rule == "*")
        and (column::host == $host or column::host == "*")
        and (column::user_id == $user or column::user_id == "*")
        and (column::specific_value == $specific_value
             or column::specific_value == $specific_value_2
             or column::specific_value == $specific_value_3
             or column::specific_value == $specific_value_4
             or column::specific_value == "*")
    }
}
