filter CheckWL_BlackListValue_Exc(string $rule_name, string $host, string $user, string $specific_value) {
    table::Common_blacklist_value {
        (column::rule == $rule_name or column::rule == "*")
        and (column::host == $host or column::host == "*")
        and (column::user_id == $user or column::user_id == "*")
        and (column::specific_value == $specific_value or column::specific_value == "*")
        and column::exclude == "yes"
    }
}
