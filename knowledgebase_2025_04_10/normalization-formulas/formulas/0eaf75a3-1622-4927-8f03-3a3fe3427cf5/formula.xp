!TEXT = '{msgid="11002"}, {$mm=WORD}/{$dd=WORD}/{$yy=WORD}, {$csv=CSV}'

action = "assign"
object = "ip_address"
status = "ongoing"

src.ip = $csv[2]
if $csv[3] != "" then
    $srchostname = $csv[3]
endif

$dot_pos = find_substr($srchostname, '.')

if $dot_pos != null then
    src.fqdn = lower($srchostname)
    src.hostname = lower(substr($srchostname, 0, $dot_pos))
else
    src.hostname = lower($srchostname)
endif

protocol = "DHCPv6"

reason = $csv[1]

# Full year notation (FIXME before 2100):
$yyyy = "20" + $yy
# Gluing the date and time (from csv) to ISO8601:
time = datetime($yyyy + "-" + $mm + "-" + $dd + "T" + $csv[0])
importance = "info"

event_src.vendor = "microsoft"
event_src.title = "windows"
event_src.category = "DHCP server"

id = "PT_Microsoft_Windows_filemonitor_11002_Request"