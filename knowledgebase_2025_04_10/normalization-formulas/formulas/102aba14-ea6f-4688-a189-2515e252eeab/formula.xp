        datafield1 = "Запланированная задача остановлена"
        object = "task"
        action = "stop"
        status = "success"
    case "1069"
        reason = "Error stopping scheduled task"
        datafield1 = "Ошибка при остановке запланированной задачи"
        object = "task"
        action = "stop"
        status = "failure"
    case "1070"
        reason = "Task completed successfully"
        datafield1 = "Задача успешно выполнена"
        object = "task"
        action = "execute"
        status = "success"
    case "1071"
        reason = "Task was canceled"
        datafield1 = "Задача отменена"
        object = "task"
        action = "stop"
        status = "success"
    case "1076"
        reason = "Error logging information"
        datafield1 = "Ошибка при регистрации информации"
        object = "resource"
        action = "info"
        status = "success"
    case "1077"
        reason = "Memory allocation error"
        datafield1 = "Ошибка при размещении памяти"
        object = "resource"
        action = "info"
        status = "success"
    case "1087"
