TABULAR = '{time=DetectedUTC},
           Analyzer,
           AnalyzerName,
           ThreatEventID,
           ThreatSeverity'

COND = in_list(["1000", "1001", "1002", "1003", "1004", "1005", "1029", "1034", "1035", "1040", "1041", "1042", "1043",
                "1044", "1045", "1046", "1047", "1048", "1049", "1062", "1063", "1064", "1065", "1066", "1067", "1068",
                "1069", "1070", "1071", "1076", "1077", "1087", "1088", "1089", "1090", "1118", "1119", "1120", "1121",
                "1122", "1124", "1125", "1126", "1127", "1128", "1129", "1200", "1201", "1202", "1203", "1204", "1333",
                "1335", "1336", "1505", "1506", "1508", "1509", "1510", "1700", "1701", "1708", "1709", "1710", "1713",
                "1714", "1715", "1716", "1718", "1719", "1720", "1725", "1726", "1800", "1801", "1802", "1803", "1804",
                "1805", "1806", "1807", "1808", "1809", "1810", "1811", "1812", "1813", "1814", "1815", "1816", "1817",
                "1818", "1900", "2005", "2006", "2015", "2016", "2201", "2202", "2204", "2208", "2216", "2264", "2422",
                "2427", "3000", "3001", "3003", "3006", "3007", "3008", "3009", "3010", "3011", "3012", "3013", "3016",
                "3018", "3019", "3022", "3023", "3024", "3025", "3026", "3027", "3028", "3029", "3030", "3031", "3032",
                "3033", "3034", "3035", "3036", "3037", "3038", "3039", "3040", "3045", "3046", "3047", "3048", "3049",
                "3050", "3051", "3052", "4651", "4700", "4701", "4702", "12000", "12002", "13001", "16000", "16001",
                "16002", "16003", "16004", "16005", "16006", "16007", "16008", "16009", "16012", "16013", "16014", "16015",
                "16016", "16017", "16018", "16019", "16020", "16021", "16022", "16023", "16024", "16025", "16026", "16027",
                "16028", "16029", "16030", "16031", "16032", "16033", "16034", "16035", "16036", "18999"], string($ThreatEventID)) and
                $AnalyzerName == "VirusScan Enterprise"

subject = "application"
# object differs
# action differs
# status differs

subject.id = $ServerID
subject.type = $Analyzer
subject.name = $AnalyzerName
subject.version = $AnalyzerEngineVersion

object.type = $ThreatType
if $ThreatName != "none" and length($ThreatName) != 0 then
    object.name = $ThreatName
endif
object.group = $ThreatCategory
if $SourceProcessName != null then
    object.property = "SourceProcessName"
    object.value = $SourceProcessName
endif

src.hostname = $AnalyzerHostName
dst.ip = $TargetIP
dst.hostname = $TargetHostName

# datafield1 - RU localization
datafield2 = $TargetUserName
datafield3 = $ThreatSeverity
datafield4 = $AnalyzerDATVersion
datafield5 = $AnalyzerDetectionMethod

msgid = string($ThreatEventID)
switch msgid
    case "1000"
        reason = "NetShield service started successfully"
        datafield1 = "Служба NetShield запущена успешно"
        object = "service"
        action = "start"
        status = "success"
        
        object.name = "netshield"
    case "1001"
        reason = "NetShield service ended successfully"
        datafield1 = "Служба NetShield остановлена успешно"
        object = "service"
        action = "stop"
        status = "success"
        
        object.name = "netshield"
    case "1002"
        reason = "Task started successfully"
        datafield1 = "Задача успешно запущена"
        object = "task"
        action = "start"
        status = "success"
    case "1003"
        reason = "Error starting task"
        datafield1 = "Ошибка запуска задачи"
        object = "task"
        action = "start"
        status = "failure"
    case "1004"
        reason = "Task has completed successfully"
        datafield1 = "Задача успешно завершена"
        object = "task"
        action = "stop"
        status = "success"
    case "1005"
        reason = "Error while stopping task"
        datafield1 = "Ошибка при остановке задачи"
        object = "task"
        action = "stop"
        status = "failure"
    case "1029"
        reason = "File to be excluded from scans"
        datafield1 = "Файл будет исключён из сканирований"
        object = "file"
        action = "info"
        status = "success"
    case "1034"
        reason = "Scan completed. No viruses found"
        datafield1 = "Сканирование завершено. Вирусов не обнаружено"
        object = "scan"
        action = "stop"
        status = "success"
    case "1035"
        reason = "Scan was cancelled"
        datafield1 = "Сканирование отменено"
        object = "scan"
        action = "stop"
        status = "success"
    case "1040"
        reason = "Activity Log error"
        datafield1 = "Ошибка журнала операций"
        object = "logging"
        action = "info"
        status = "success"
    case "1041"
        reason = "Scan reports memory allocation error"
        datafield1 = "Сканирование сообщило об ошибке размещения памяти"
        object = "scan"
        action = "info"
        status = "success"
    case "1042"
        reason = "Path to the object is too long"
        datafield1 = "Путь к объекту слишком длинный"
        object = "resource"
        action = "info"
        status = "success"
    case "1043"
        reason = "Media is write protected"
        datafield1 = "Носитель защищен от записи"
        object = "device"
        action = "info"
        status = "success"
    case "1044"
        reason = "Specified media not found"
        datafield1 = "Указанный носитель не найден"
        object = "device"
        action = "info"
        status = "success"
    case "1045"
        reason = "Specified scan item is invalid"
        datafield1 = "Указанный для сканирования элемент недопустим"
        object = "file"
        action = "info"
        status = "success"
    case "1046"
        reason = "File I/O errors"
        datafield1 = "Ошибки ввода/вывода файла"
        object = "file"
        action = "info"
        status = "success"
    case "1047"
        reason = "Disk I/O errors"
        datafield1 = "Ошибки ввода/вывода диска"
        object = "device"
        action = "info"
        status = "success"
    case "1048"
        reason = "Scan reports general system error"
        datafield1 = "Сканирование сообщило об общей системной ошибке"
        object = "scan"
        action = "info"
        status = "success"
    case "1049"
        reason = "Scan reported an internal application error"
        datafield1 = "Сканирование сообщило о внутренней ошибке приложения"
        object = "scan"
        action = "info"
        status = "success"
    case "1063"
        reason = "Invalid options specified"
        datafield1 = "Указаны недопустимые параметры"
        object = "resource"
        action = "info"
        status = "success"
    case "1064"
        reason = "Service started"
        datafield1 = "Служба запущена"
        object = "service"
        action = "start"
        status = "success"
    case "1065"
        reason = "Service ended"
        datafield1 = "Служба завершена"
        object = "service"
        action = "stop"
        status = "success"
    case "1066"
        reason = "Task started successfully"
        datafield1 = "Задача успешно запущена"
        object = "task"
        action = "start"
        status = "success"
    case "1067"
        reason = "Unable to start scheduled task"
