TEXT = '{"<"NUMBER">"?} {time=DATETIME} {event_src.ip=IPV4|event_src.ip=IPV6|$Computer=HOSTNAME} 
        CEF:0|IT-Bastion LLC|SKDPU-NT|{datafield5=UNTIL("|")}
        {msgid="SKDPUNT.INCIDENT.00001"}|{chain_id=WORDDASH}|{NUMBER}|act=SKDPUNT.INCIDENT.NEW {$kv=KEYVALUE(" ", "=")}'

COND = $kv["cat"] == "PERMISSION_DENIED"

action = "detect"
object = "alert"
status = "success"

#$temp_json = replace(replace($kv["reason"], "\"", "'"), "}}", "} }")

#subformula "parse_json"
#    JSON = ''
#endsubformula

#submessage("JSON", "parse_json", $temp_json)

if find_substr($kv["suser"], "@") != null then
    $temp_acc = csv($kv["suser"], "@", "")
    subject.application.account.domain = $temp_acc[length($temp_acc) - 1]
    subject.application.account.name = $temp_acc[0]
else
    subject.application.account.name = $kv["suser"]
endif

object.application.account.session_id = $kv["externalId"]
object.application.account.name = $kv["duid"]

if $event_type != null then
    object.property = "event type"
    object.value = $event_type
endif    

dst.hostname = $kv["dhost"]
dst.ip = $kv["dst"]

if coalesce(maybe_ipv4($kv["src"]),maybe_ipv6($kv["src"])) != null then
    src.ip = $kv["src"]
else    
    src.hostname = $kv["src"]
endif

protocol.layer7 = $kv["destinationServiceName"]

logon_service = $kv["app"]

datafield1 = $kv["cat"]      # incident category
datafield8 = $kv["dvchost"]  # gateway name
datafield9 = $kv["cnt"]      # incident impact
# datafield5 skdpu nt version

if object.application.account.session_id != $session_id 
    or object.application.account.session_id  == null then
    datafield10 = $session_id  # sesion id on access gw
endif

datafield11 = $wabsession_id          # session id in skdpu nt
datafield12 = $event_hash             # event hash
datafield14 = $kv["reason"]           # event data not a json

importance = "medium"

event_src.vendor =  "it_bastion"
$dot_pos = find_substr($Computer, '.')
if $dot_pos != null then
    event_src.fqdn = lower($Computer)
    if substr($Computer, 0, $dot_pos) != string(number(substr($Computer, 0, $dot_pos))) then event_src.hostname = lower(substr($Computer, 0, $dot_pos)) endif
else
    event_src.hostname = lower($Computer)
endif
event_src.title = "skdpu_nt"
event_src.category = "Other"

id = "PT_IT_Bastion_SKDPU_NT_cef_sftp_file_access_failure"