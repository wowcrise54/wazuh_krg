!TABULAR = "{$tmp_object.state = event_id},
            {subject.name = username},
            {msgid = id},
            {time = time},
            {object.id = document_id},
            {subject.privileges = permission},
            {subject.id = user_id},
            {object.type = is_new_format},
            {reason = event_id},
            {$tmp_datafield1 = superadmin},
            {$tmp_datafield2 = with_notebook },
            {$tmp_action = event_id}"

subject = "account"
object = "file"
status = "success"
src.ip = $ip

switch $tmp_datafield1
    case "0"
        datafield1 = "No"
    case "1"
        datafield1 = "Yes"
endswitch

switch $tmp_datafield2
    case "0"
        datafield2 = "No"
    case "1"
        datafield2 = "Yes"
endswitch


switch $tmp_object.state
    case "7"
        object.state = "Uploading the document pages"
    case "4"
        object.state = "Creating the document"
    case "5"
        object.state = "Changing the document"
    case "6"
        object.state = "Deleting the document"
    case "1"
        object.state = "Creating the resolution"
