    case "22"
        object.state = "Changing of the urgency question"
    case "38"
        object.state = "The document was signed by one's own hand"
    case "39"
        object.state = "The agreement of document was runned"
    case "40"
        object.state = "The participant of agreement was deleted"
    case "41"
        object.state = "The participant of agreement was added"
    case "42"
        object.state = "The agreement was stopped"
    case "43"
        object.state = "It was agreed"
    case "44"
        object.state = "The agreement was finished"
    case "45"
        object.state = "The urgency of agreement was changed"
    case "46"
        object.state = "Rerouting"
    case "47"
        object.state = "Return at the initiator"
    case "48"
        object.state = "Return to the MO"
    case "51"
        object.state = "Return to the previous participant"
    case "49"
        object.state = "Distribution at the registration"
    case "50"
        object.state = "Remove from distribution at the registration"
    case "52"
        object.state = "Opening the document"
    case "53"
        object.state = "The final deleting"
    case "54"
        object.state = "Rerouting of the document to another recipient"
    case "55"
        object.state = "The document was transferred into incoming requests of citizens"
    case "56"
        object.state = "The document was transferred into incoming"
    case "57"
        object.state = "Return agreement for signature"
endswitch

