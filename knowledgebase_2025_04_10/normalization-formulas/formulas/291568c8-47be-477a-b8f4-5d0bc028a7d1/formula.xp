TEXT = '{"<"NUMBER">"?}{":"?} {time=DATETIME} {"Message forwarded from"?}
        {event_src.ip=IPV4|event_src.ip=IPV6|event_src.hostname=HOSTNAME|"(none)"|}{":"?}{WORD?}{":"WORD?}
        audit: {msgid="GROUP_Remove"} {subject.name=WORDDASH} {$status="OK"|"FAIL"|"FAILURE"}
        rmgroup {object.name=WORDDASH}'

subject = "account"
action = "remove"
object = "user_group"
if $status == "OK" then
    status = "success"
else
    status = "failure"
endif

event_src.vendor = "ibm"
event_src.title = "aix"
event_src.category = "Operating system"

id = "PT_IBM_AIX_syslog_group_remove"
importance = "info"