TEXT = '{"<"NUMBER">"?} {time=DATETIME} {$Computer=STRING} {event_src.subsys="rdpproxy"}
        {"["object.process.id=NUMBER"]"?}: [RDP Session] {$kv=KEYVALUE(" ", "=", "\\"")}'

COND = $kv["type"] == "FOREGROUND_WINDOW_CHANGED"

action = "info"
object = "application"
status = "success"

if find_substr($kv["account"], "\\") != null then
    $temp_acc_1 = csv($kv["account"], "\\", "")
    object.account.name = $temp_acc_1[length($temp_acc_1) - 1]
    object.account.domain = $temp_acc_1[0]
elif find_substr($kv["account"], "@") != null then
    $temp_acc_2 = csv($kv["account"], "@", "")
    object.account.name = $temp_acc_2[0]
    object.account.domain = $temp_acc_2[1]
else
    object.account.name = $kv["account"]
endif

src.ip = $kv["client_ip"]
dst.ip = $kv["target_ip"]
protocol.layer7 = "rdp"

logon_service = $kv["service"]

if $kv["client_ip"] == $kv["target_ip"] then
    logon_auth_method = "local"
else
    logon_auth_method = "remote"
endif

datafield1 = $kv["session_id"]  # Идентификатор сессии
datafield2 = $kv["class_name"]  # Приложение

# datafield3 - имя пользователя WAB
# datafield4 - домен пользователя WAB
if find_substr($kv["user"], "\\") != null then
    $temp_acc_3 = csv($kv["user"], "\\", "")
    datafield3 = $temp_acc_3[length($temp_acc_1) - 1]
    datafield4 = $temp_acc_3[0]
elif find_substr($kv["user"], "@") != null then
    $temp_acc_4 = csv($kv["user"], "@", "")
    datafield3 = $temp_acc_4[0]
    datafield4 = $temp_acc_4[1]
else
    datafield3 = $kv["user"]
endif

datafield5 = $kv["device"]        # Наименование устройства в WAB
datafield8 = $kv["text"]          # Текст
datafield9 = $kv["command_line"]  # Процесс

msgid = $kv["type"]
importance = "info"

event_src.vendor =  "it_bastion"
$dot_pos = find_substr($Computer, '.')
if $dot_pos != null then
    event_src.fqdn = lower($Computer)
    if substr($Computer, 0, $dot_pos) != string(number(substr($Computer, 0, $dot_pos))) then event_src.hostname = lower(substr($Computer, 0, $dot_pos)) endif
else
    event_src.hostname = lower($Computer)
endif
event_src.title = "skdpu_nt"
event_src.category = "Other"

id = "PT_IT_Bastion_SKDPU_NT_syslog_session_foreground_window"
