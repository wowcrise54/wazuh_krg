TEXT = '{"<"NUMBER">"?} {$kv=KEYVALUE(" ", "=", "\\"")}'

COND = $kv["devid"] != null
       and $kv["devname"] != null
       and $kv["logid"] == "0100040704"

action = "info"
object = "system"
status = "success"

datafield1 = $kv["cpu"]                                # загрузка процессора
datafield2 = $kv["mem"]                                # загрузка памяти
datafield3 = $kv["totalsession"]                       # количество отслеживаемых соединений
datafield4 = $kv["vd"]                                 # Virtual domain name
datafield9 = join([$kv["type"], $kv["subtype"]], "|")  # Event type
datafield11 = $kv["action"]                            # Action

time = join([$kv["date"], $kv["time"]], " ")
msgid = $kv["logid"]
importance = "info"

event_src.vendor = "fortinet"
event_src.title = "fortigate"
event_src.hostname = $kv["devname"]
event_src.id = $kv["devid"]
event_src.category = "Firewall"

id = "PT_Fortinet_Fortigate_syslog_40704_LOG_ID_EVENT_SYS_PERF"
