TEXT = '<{NUMBER}>{time=DATETIME}{WORDDASH|STRING} vault[{NUMBER}]: {$json=REST}' 
COND = find_substr($json, "\"mount_type\":\"kv\"") != null 
       and find_substr($json, "\"operation\":\"patch\"") != null

submessage("JSON","json_in_syslog_secret_patched", $json)

subformula 'json_in_syslog_secret_patched'
    JSON = ''
    
    if $error != null then
        status = "failure"
        reason = $error
        importance = "low"
    else
        status = "success"
        importance = "medium"
    endif
    
    subject.account.name = $auth["display_name"]
    subject.account.privileges = join($auth["policies"], ", ")
    
    $temp = csv($request["path"], "/", " ")
    object.name = $temp[length($temp) - 1]
    object.fullpath = $request["path"]
    object.path = strip(object.fullpath, "", object.name)
    
    src.ip = $request["remote_address"]
    src.port = $request["remote_port"]
endsubformula

subject = "account"
action = "create"
object = "resource"

event_src.vendor = "hashicorp"
event_src.title = "vault"
event_src.category = "Application security"

id = "PT_Hashicorp_Vault_syslog_Secret_patched"