!TABULAR = 'Version,
            DateTime,
            Severity,
            MessageID'

!COND = $Location == "com.sap.engine.services.security.authentication.logincontext.table"
        and find_substr($MsgText, "LOGIN.OK") != null

subject = "account"
action = "login"
object = "system"
status = "success"

subject.account.id = lower($User)

submessage("TEXT", "parse_msg_text", $MsgText)
subformula "parse_msg_text"
    TEXT = 'LOGIN.OK User: {STRING} IP Address: {src.ip=IPV4} {REST}'
endsubformula
if $Session != '' then
    subject.account.session_id = $Session
endif

if $Application != '' then
    datafield1 = $Application   # application
endif
if $Transaction != '' then
    datafield2 = $Transaction   # transaction id
endif
if $ThreadName != '' then
    datafield3 = $ThreadName    # thread name
endif
if $DsrComponent != '' then
    datafield5 = $DsrComponent  # component name
endif

if ($TimeZone != null) then
    time = $DateTime + "#" + $TimeZone
else
    time = $DateTime
endif
importance = "info"

category.generic = "Operating System"
category.high = "Access Management"
category.low = "Communication"

event_src.vendor = "sap"
event_src.title = "sap_as_java"
event_src.subsys = "security audit"
event_src.category = "Application server"

id = "PT_SAP_SAP_AS_JAVA_Security_Audit_filemonitor_User_logon_Version_20"