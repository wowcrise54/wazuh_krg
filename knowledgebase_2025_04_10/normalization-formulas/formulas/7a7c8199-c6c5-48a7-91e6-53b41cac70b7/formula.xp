id = "PT_Avaya_ERS_5500_syslog_login_session_stopped"

TEXT = '{"<"NUMBER">"}{time=DATETIME}{event_src.hostname=HOSTNAME|STRING}  :
        # {NUMBER} Connection closed ({$reason = STRING+} IP address: {src.ip = IPV4| src.ip = IPV6}'

reason = strip ($reason, '', '),')

subject = "account"
action = "stop"
object = "session"
status = "success"

importance = "info"

event_src.title = "ers_5500"
event_src.vendor = "avaya"
event_src.category = "Network device"